# ══════════════════════════════════════════════════════
#  PallaPay — Railway Environment Variables
#  Railway dashboard → Service → Variables tab mein yeh set karo
# ══════════════════════════════════════════════════════

# Telegram Bot Token (@BotFather se milta hai)
BOT_TOKEN=1234567890:ABCDefghIJKlmnoPQRstuvWXyz

# Telegram Admin IDs (comma-separated, apna Telegram numeric ID dalo)
# Kaise pata kare: @userinfobot ko message karo
ADMIN_IDS=123456789,987654321

# Admin API token (koi bhi secret string, website ke admin panel ke liye)
ADMIN_TOKEN=pallapay2025secret

# PostgreSQL URL — Railway automatically set karta hai jab PostgreSQL add karo
# Manually set karne ki zaroorat nahi
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Port — Railway automatically set karta hai, mat change karo
PORT=8080
